# ============================================================================
# pro-sender / Signal — environment configuration
# Copy this file to `.env.local` and fill in the blanks.
# ============================================================================

# ---- Database ----
# Relative to the project root. The folder is created automatically. Leave the
# default unless you want to point to a different file.
DATABASE_PATH=data/pro-sender.db

# ---- Authentication ----
# Single-user admin login. When either ADMIN_PASSWORD or AUTH_SECRET is empty,
# auth is DISABLED and every page is publicly reachable — fine for local dev,
# but always set both on the VPS.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Random secret used to sign session cookies. Generate one with:
#   openssl rand -hex 32     (or: node -e "console.log(crypto.randomBytes(32).toString('hex'))")
AUTH_SECRET=

# ---- SMS provider ----
# Which provider implementation to use. "mock" for local dev, "mmdsmart" for live.
SMS_PROVIDER=mock

# MMDSmart / MessageWhiz API. Get your API key from the mmdsmart dashboard.
# Base URL defaults to https://sms.mmdsmart.com — switch to
# https://sms.messagewhiz.com if mmdsmart routes you to the upstream platform.
MMDSMART_API_BASE_URL=https://sms.mmdsmart.com
MMDSMART_API_KEY=

# Default sender ID / from name shown on the recipient's phone. Some countries
# require pre-registered alphanumeric senders.
MMDSMART_DEFAULT_SENDER=Signal

# Send a single POST /sms per recipient when the recipient count is at or below
# this threshold. Beyond it, /api/send switches to the broadcast endpoint.
MMDSMART_BROADCAST_THRESHOLD=5

# ---- Webhook ----
# Public URL of THIS app. MessageWhiz will POST delivery receipts to
# {APP_BASE_URL}/api/webhook/sms. Must be reachable from the public internet
# (e.g. your VPS domain, or an ngrok tunnel during local dev — see
# `scripts/dev-tunnel.ps1`).
APP_BASE_URL=http://localhost:3000

# Optional shared secret. If set, the webhook route rejects requests whose
# X-Webhook-Secret header does not match. Generate with: openssl rand -hex 32
MMDSMART_WEBHOOK_SECRET=
